# Firebase web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# Store mode: use "firebase" for hosted internal beta, "local" for local-only development
NEXT_PUBLIC_NATIVE_ACTION_ITEM_STORE_MODE=firebase
NEXT_PUBLIC_COLLATERAL_STORE_MODE=firebase
NEXT_PUBLIC_FIREBASE_AUTH_ENABLED=true

# Optional: keep false unless the dashboard projection document is populated remotely
NEXT_PUBLIC_FIREBASE_DASHBOARD_READS_ENABLED=false
